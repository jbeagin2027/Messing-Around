class PieceType{
    
    private final ArrayList<Vect> moveOptions = new ArrayList();
    private final ArrayList<Vect> captureOptions = new ArrayList();
    private final boolean isPawn, isRoyal, rookish;//royal pieces can be checkmated, stalemated, and castle with a rookish piece
    //pawns can enpassant, promote, rookish pieces can castle with the king if they are orthogonol and both unmoved
    private final String name;//The name of the piece is its display name, which should be like B or p
    private final Team team; //team names should be like, "White" "Black" "Green" or single-word capitalized with no spaces 
    
    public PieceType(ArrayList<Vect> moves, ArrayList<Vect> caps, boolean pawn, boolean royal, boolean castler, Team teamIn, String nameIn){
        
        for(Vect move : moves){
            moveOptions.add(move);
        }
        for(Vect cap : caps){
            moveOptions.add(cap);
        }
        isPawn = pawn;
        isRoyal = royal;
        rookish = castler;
        name = nameIn;
        team = teamIn;
        
    }
    
    class Piece{
        
        private int xpo;
        private int ypo;
        private Vect lastMove = new Vect();
        private boolean everMoved;
        
        public int getX(){return xpo;}
        public int getY(){return ypo;}
        public void move(Vect move){
            lastMove = move;
            xpo+=move.getX();
            ypo+=move.getY();
            everMoved=false;
        }
        
        public Piece(Vect last, boolean ever, int x, int y){
            
            lastMove = last;
            everMoved = ever;
            xpo = Math.clamp(x,0,7);
            ypo = Math.clamp(y,0,7);
            
        }
        @Override
        public String toString(){return name;}
        
        public String getTeam(){return team.toString();}
        
        public boolean isRook(){return rookish;}
        public boolean isPawn(){return isPawn;}
        public boolean isRoyal(){return isRoyal;}
        public boolean hasMoved(){return everMoved;}
        public Vect lastMove(){return lastMove;}
        
        public boolean can(Vect attempt, boolean isOccupied){
            int x = attempt.getX();
            int y = attempt.getY();
            if((x+xpo)>=0&&(y+ypo)>=0&&(x+xpo)<=Vect.range&&(y+ypo)<=Vect.range){
                if(isOccupied){
                    for(Vect cap : captureOptions){
                        if(cap.toString().equals(attempt.toString())){return true;}
                    }
                    return false;
                }else{
                    for(Vect move : moveOptions){
                        if(move.toString().equals(attempt.toString())){return true;}
                    }
                    return false;
                }
            }else return false;
            
        }
        
    }
    
}

